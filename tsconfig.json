{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    
    "jsx": "preserve",
    "incremental": true,

    // ✅ 🔥 FIX: Add Jest + Node types
    "types": ["jest", "node"],

    // ✅ Better DX
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },

    "plugins": [
      {
        "name": "next"
      }
    ]
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],

  // ✅ Optional but recommended
  "exclude": [
    "node_modules",
    "dist"
  ]
}